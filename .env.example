# Frontend → Backend (browser-side)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Django
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=*
DJANGO_SECRET_KEY=dev-insecure-secret-key

# CORS / CSRF (dev)
CORS_ALLOW_ALL_ORIGINS=1
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=

# Postgres (docker-compose)
POSTGRES_DB=vehsl
POSTGRES_USER=vehsl
POSTGRES_PASSWORD=vehsl

# Dev admin (auto-created on container start)
DJANGO_SUPERUSER_EMAIL=admin@vehsl.local
DJANGO_SUPERUSER_PASSWORD=admin

# Email verification OTP
EMAIL_VERIFICATION_CODE_TTL_SECONDS=600
EMAIL_VERIFICATION_TOKEN_TTL_SECONDS=1800
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
EMAIL_VERIFICATION_MAX_ATTEMPTS=5

# Transactional email
# Option 1: SendGrid API
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Option 2: SMTP
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=1
EMAIL_USE_SSL=0
DEFAULT_FROM_EMAIL=no-reply@vehsl.local
